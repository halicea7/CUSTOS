# API
SECRET_KEY=changeme
ACCESS_TOKEN_EXPIRE_MINUTES=480

# GitHub
# Required scopes: repo:read, checks:write
GITHUB_WEBHOOK_SECRET=your_webhook_secret
GITHUB_TOKEN=ghp_your_token

# Database (localhost for local dev; swap hostname to "postgres" for Docker)
DATABASE_URL=postgresql+asyncpg://Custos:Custos@localhost:5432/Custos

# Redis (localhost for local dev; swap hostname to "redis" for Docker)
REDIS_URL=redis://localhost:6379

# Ollama (local LLM — no code leaves GW infrastructure)
OLLAMA_BASE_URL=http://your-ollama-node:11434
OLLAMA_MODEL=qwen2.5-coder:32b

# Analysis limits
CLONE_BASE_DIR=/tmp/Custos_clones
MAX_FILE_SIZE_KB=500
MAX_FILES_PER_REPO=200
